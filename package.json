{
  "name": "gts-front-end",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "generate:api": "openapi-typescript https://localhost:44317/swagger/v1/swagger.json -o src/app/core/api/generated/api-types.ts",
    "generate:api:deploy": "openapi-typescript http://108.174.145.123:5000/swagger/v1/swagger.json -o src/app/core/api/generated/api-types.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@playwright/test": "^1.58.2",
    "jsdom": "^27.1.0",
    "openapi-typescript": "^7.4.2",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
